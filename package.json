{
  "name": "voltaire-ai",
  "version": "1.0.0",
  "description": "Modular autonomous on-chain agent framework — daily portfolio rebalancer",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:agent\"",
    "dev:api": "cd api && npx ts-node-dev index.ts",
    "dev:agent": "cd agents/rebalancer && npx ts-node index.ts",
    "agent": "cd agents/rebalancer && npx ts-node index.ts",
    "build": "tsc --build",
    "test": "jest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.0",
    "jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@langchain/core": "^0.3.80",
    "@langchain/langgraph": "^0.2.74",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node-cron": "^3.0.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "ethers": "^6.16.0",
    "express": "^4.18.0",
    "node-cron": "^3.0.3",
    "uuid": "^14.0.0"
  }
