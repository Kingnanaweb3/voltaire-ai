# ─── Uniswap ───────────────────────────────────────────────
UNISWAP_API_KEY=your_uniswap_api_key_here
UNISWAP_API_URL=https://trade-api.gateway.uniswap.org/v1

# ─── KeeperHub ─────────────────────────────────────────────
KEEPERHUB_API_KEY=your_keeperhub_api_key_here
KEEPERHUB_MCP_URL=https://mcp.keeperhub.io

# ─── 0G Network ────────────────────────────────────────────
OG_RPC_URL=https://rpc-testnet.0g.ai
OG_STORAGE_URL=https://storage-testnet.0g.ai
OG_COMPUTE_URL=https://compute-testnet.0g.ai
OG_COMPUTE_MODEL=qwen3-6b-plus

# ─── Wallet ────────────────────────────────────────────────
AGENT_PRIVATE_KEY=your_wallet_private_key_here
AGENT_WALLET_ADDRESS=your_wallet_address_here

# ─── Chain ─────────────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org
CHAIN_ID=84532

# ─── API Server ────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Agent Config ──────────────────────────────────────────
REBALANCE_CRON=0 9 * * *
DRIFT_THRESHOLD=0.05
TARGET_ETH_RATIO=0.60
TARGET_USDC_RATIO=0.40
